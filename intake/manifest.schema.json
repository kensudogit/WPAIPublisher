{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WPAIPublisher Intake Manifest",
  "description": "Codex等のAIツール出力を受け取る際のマニフェスト形式",
  "type": "object",
  "required": ["version", "source", "target", "files"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0",
      "description": "マニフェストバージョン"
    },
    "source": {
      "type": "object",
      "required": ["tool", "generated_at"],
      "properties": {
        "tool": {
          "type": "string",
          "enum": ["codex", "cursor", "copilot", "other"],
          "description": "生成元AIツール"
        },
        "prompt": {
          "type": "string",
          "description": "元プロンプトの要約（任意）"
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "target": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["theme", "block", "page", "template-part", "custom-css"],
          "description": "WordPressへの反映種別"
        },
        "theme_slug": {
          "type": "string",
          "description": "対象テーマのスラッグ"
        },
        "page_slug": {
          "type": "string",
          "description": "固定ページのスラッグ（type=pageの場合）"
        },
        "block_name": {
          "type": "string",
          "description": "ブロック名（type=blockの場合）"
        }
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "role"],
        "properties": {
          "path": {
            "type": "string",
            "description": "incoming/ からの相対パス"
          },
          "role": {
            "type": "string",
            "enum": ["html", "css", "js", "php", "json", "asset", "other"]
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "notes": {
      "type": "string",
      "description": "変換時の注意事項"
    }
  }
}
