# WPAIPublisher 環境変数
# コピー: cp config/.env.example config/.env

# WordPress REST API - Staging
# ローカル Docker: http://localhost:8088 （docker-compose.staging.yml）
WP_STAGING_URL=http://localhost:8088
WP_STAGING_USER=admin
WP_STAGING_APP_PASSWORD=
WP_STAGING_LOCAL_PATH=staging

# WordPress REST API - Production
WP_PROD_URL=https://www.example.com
WP_PROD_USER=deploy-bot
WP_PROD_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# SSH / WP-CLI（リモートサーバー用。ローカルでは空でOK）
WP_STAGING_SSH=
WP_STAGING_PATH=
WP_PROD_SSH=
WP_PROD_PATH=

# Git
GIT_REPO=git@github.com:your-org/wp-content.git
GIT_STAGING_BRANCH=staging
GIT_PRODUCTION_BRANCH=main

# マルチAI API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GITHUB_TOKEN=

# 通知（任意）
SLACK_WEBHOOK_URL=

# PostgreSQL（Railway Postgres の DATABASE_URL を Reference）
# 例: postgresql://user:pass@host:5432/railway
DATABASE_URL=
