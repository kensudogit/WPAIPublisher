# WPAIPublisher 環境変数
# コピー: cp config/.env.example config/.env

# WordPress REST API - Staging
WP_STAGING_URL=https://staging.example.com
WP_STAGING_USER=deploy-bot
WP_STAGING_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# WordPress REST API - Production
WP_PROD_URL=https://www.example.com
WP_PROD_USER=deploy-bot
WP_PROD_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# SSH / WP-CLI（リモートサーバー用、任意）
WP_STAGING_SSH=user@staging-server
WP_STAGING_PATH=/var/www/staging
WP_PROD_SSH=user@prod-server
WP_PROD_PATH=/var/www/production

# Git
GIT_REPO=git@github.com:your-org/wp-content.git
GIT_STAGING_BRANCH=staging
GIT_PRODUCTION_BRANCH=main

# マルチAI API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GITHUB_TOKEN=ghp_...

# 通知（任意）
SLACK_WEBHOOK_URL=
